# =============================================================================
# Trustless Hiring Marketplace - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets (CRITICAL - Never commit these)
# -----------------------------------------------------------------------------
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
.env*.local
*.pem
*.key
*.cert
secrets/
credentials/

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build & Output
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
coverage/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
pgdata/
data/postgres/

# -----------------------------------------------------------------------------
# ZK Proof Artifacts (can be large)
# -----------------------------------------------------------------------------
circuits/build/
*.ptau
*.zkey
*.wtns
proof-artifacts/

# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
.history/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.lnk

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.cache/
.temp/
.tmp/
*.bak
*.backup
.turbo/

# Auto-generated document formats
*.docx
*.pdf
